                 Order="Default"
                 Priority="0"
                 Clicked="AccountSelect"/>
        <ToolbarItem Order="Primary" Priority="0" />
        <ToolbarItem Order="Primary" Priority="0" />
        <ToolbarItem Order="Primary" Priority="0" />
        <ToolbarItem Order="Primary" Priority="0" />
        <ToolbarItem Order="Primary" Priority="0" />
        <ToolbarItem Order="Primary" Priority="0" />
        <ToolbarItem Order="Primary" Priority="0" />
        <ToolbarItem Order="Primary" Priority="0" />
    </TabbedPage.ToolbarItems>

    <NavigationPage  Title="PACIENTES" >
            <x:Arguments>
                <local:BuscarPacienteTerapeuta />
            </x:Arguments>
        </NavigationPage>
        <NavigationPage Title="CUESTIONARIOS">
            <x:Arguments>
                <local:AsignarCuestionarioPaciente />
            </x:Arguments>
        </NavigationPage>

</TabbedPage>